import 'package:url_launcher/url_launcher.dart';

class WhatsAppService {
  static Future<void> siapkanPesanCustomer({
    required String nomorWaCustomer,
    required String namaCustomer,
    required List<Map<String, dynamic>> listBarang, // Mengambil data barang yang dibeli
    required int totalHarga,
  }) async {
    // 1. Menyusun daftar barang menjadi teks berbutir (bullet points)
    String detailBarang = '';
    for (var item in listBarang) {
      detailBarang += '- ${item['nama']} (x${item['jumlah']})\n';
    }

    // 2. Format total harga ke rupiah agar rapi (Opsional, sesuaikan dengan helper kamu)
    String totalFormat = totalHarga.toString(); 

    // 3. Menyusun template pesan otomatis
    final pesan = '''
Halo Kak *$namaCustomer*,

Terima kasih sudah berbelanja di *tsamaniya*. Berikut adalah rincian pesanan Kakak:
$detailBarang
*Total Pembayaran:* Rp $totalFormat

Pesanan Kakak sedang kami siapkan ya. Mohon ditunggu! 🙏
''';

    // 4. Pastikan format nomor WA diawali dengan kode negara (62) tanpa spasi/tanda minus
    // Contoh input: "0812345678" -> diubah jadi "62812345678"
    String nomorBersih = nomorWaCustomer;
    if (nomorBersih.startsWith('0')) {
      nomorBersih = '62' + nomorBersih.substring(1);
    }

    final url = 'https://wa.me/$nomorBersih?text=${Uri.encodeComponent(pesan)}';
    
    // 5. Eksekusi peluncuran URL WhatsApp
    final uri = Uri.parse(url);
    if (await canLaunchUrl(uri)) {
      await launchUrl(uri, mode: LaunchMode.externalApplication); // Membuka langsung di aplikasi WA
    } else {
      throw 'Tidak dapat membuka WhatsApp';
    }
  }
}